{
  "name": "@sakura/api",
  "version": "1.0.0",
  "private": true,
  "description": "Sakura Express Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env -- prisma generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "db:seed": "tsx packages/database/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "dotenv-expand": "^12.0.3",
    "express": "^4.19.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "tsx": "^4.7.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.10.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/prisma/seed.ts"
  }
}
