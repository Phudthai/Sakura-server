// ==============================================
// Sakura Database Schema
// ==============================================
// Matches deployed DB DDL — only tables used by API
//
// @docs https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Monorepo: app resolves @prisma/client from repo root; generate into root node_modules
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================
// User Management
// ==============================================

model User {
  id                Int      @id @default(autoincrement())
  user_code         String   @unique @map("user_code")
  username          String?  @unique
  external_id       String?  @unique @map("external_id")
  email             String?  @unique
  password          String?
  name              String?
  phone             String?
  role              UserRole @default(CUSTOMER)
  is_email_verified Boolean  @default(false) @map("is_email_verified")
  is_active         Boolean  @default(true) @map("is_active")
  created_at        DateTime @default(now()) @map("created_at")
  updated_at        DateTime @updatedAt @map("updated_at")

  auction_requests    AuctionRequest[]
  wallet              UserWallet?
  payment_obligations PaymentObligation[]
  payment_receipts    PaymentReceipt[]
  shipping_addresses  UserShippingAddress[]
  domestic_shipments  DomesticShipment[]

  @@index([email])
  @@index([user_code])
  @@index([created_at])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

model UserShippingAddress {
  id             Int      @id @default(autoincrement())
  user_id        Int      @map("user_id")
  label          String?
  recipient_name String   @map("recipient_name")
  phone          String?
  address_line1  String   @map("address_line1")
  address_line2  String?  @map("address_line2")
  subdistrict    String
  district       String
  province       String
  postal_code    String   @map("postal_code")
  country        String   @default("TH")
  is_default     Boolean  @default(false) @map("is_default")
  created_at     DateTime @default(now()) @map("created_at")
  updated_at     DateTime @updatedAt @map("updated_at")

  user               User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payment_receipts   PaymentReceipt[]
  domestic_shipments DomesticShipment[]

  @@index([user_id])
  @@map("user_shipping_addresses")
}

// ==============================================
// Lot (จัดส่ง)
// ==============================================

model Lot {
  id                 Int       @id @default(autoincrement())
  lot_code           String    @map("lot_code")
  intl_shipping_type String    @map("intl_shipping_type")
  start_lot_at       DateTime? @map("start_lot_at")
  end_lot_at         DateTime? @map("end_lot_at")
  arrive_at          DateTime? @map("arrive_at")
  is_arrived         Boolean   @default(false) @map("is_arrived")
  is_delayed         Boolean   @default(false) @map("is_delayed")
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")

  auction_requests AuctionRequest[]

  @@unique([lot_code, intl_shipping_type])
  @@index([lot_code])
  @@index([intl_shipping_type])
  @@index([intl_shipping_type, end_lot_at])
  @@map("lots")
}

// ==============================================
// Auction Tracking
// ==============================================

model AuctionRequest {
  id                 Int       @id @default(autoincrement())
  user_id            Int?      @map("user_id")
  url                String
  web                String?   @default("yahoo")
  item_id            String?   @map("item_id")
  title              String?
  image_url          String?   @map("image_url")
  end_time           DateTime? @map("end_time")
  status             String    @default("pending")
  current_price      Int?      @map("current_price")
  current_price_baht Int?      @map("current_price_baht")
  note               String?
  bid_result         String?   @map("bid_result")
  weight_gram        Int?      @map("weight_gram")
  intl_shipping_type String?   @map("intl_shipping_type")
  lot_id             Int?      @map("lot_id")
  bought_at          DateTime? @map("bought_at")
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")

  user                User?               @relation(fields: [user_id], references: [id], onDelete: SetNull)
  lot                 Lot?                @relation(fields: [lot_id], references: [id], onDelete: SetNull)
  price_logs           AuctionPriceLog[]
  payment_obligations  PaymentObligation[]
  delivery_stages      DeliveryStage[]
  domestic_shipment_id Int?                 @map("domestic_shipment_id")
  domestic_shipment    DomesticShipment?      @relation(fields: [domestic_shipment_id], references: [id], onDelete: SetNull)
  domestic_shipment_item DomesticShipmentItem?

  @@index([status])
  @@index([user_id])
  @@index([web])
  @@index([created_at])
  @@index([status, created_at])
  @@index([user_id, created_at])
  @@index([domestic_shipment_id])
  @@map("auction_requests")
}

model AuctionPriceLog {
  id                 Int      @id @default(autoincrement())
  auction_request_id Int      @map("auction_request_id")
  price              Int
  bid_count          Int      @default(0) @map("bid_count")
  status             String   @default("pending")
  bidded_by          Int?     @map("bidded_by")
  recorded_at        DateTime @default(now()) @map("recorded_at")

  auction_request AuctionRequest @relation(fields: [auction_request_id], references: [id], onDelete: Cascade)
  staff           Staff?         @relation(fields: [bidded_by], references: [id], onDelete: SetNull)

  @@index([auction_request_id])
  @@index([bidded_by])
  @@index([status])
  @@index([status, recorded_at])
  @@map("auction_price_logs")
}

model Staff {
  id         Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  price_logs AuctionPriceLog[]

  @@map("staffs")
}

// ==============================================
// Exchange rates (JPY → THB tiers)
// ==============================================

model JpyThbRateTier {
  id         Int      @id @default(autoincrement())
  min_jpy    Int      @map("min_jpy")
  max_jpy    Int?     @map("max_jpy")
  rate       Decimal  @db.Decimal(10, 6)
  sort_order Int      @default(0) @map("sort_order")
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([sort_order])
  @@map("jpy_thb_rate_tiers")
}

// เรทค่าขนส่งระหว่างประเทศ: บาทต่อกรัม (เดิม hardcode air 0.59 / sea 0.35)
model IntlShippingGramRate {
  id                 Int      @id @default(autoincrement())
  intl_shipping_type String   @unique @map("intl_shipping_type")
  baht_per_gram      Decimal  @map("baht_per_gram") @db.Decimal(10, 6)
  updated_at         DateTime @updatedAt @map("updated_at")

  @@map("intl_shipping_gram_rates")
}

// ==============================================
// User Wallet
// ==============================================

model UserWallet {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique @map("user_id")
  balance    Int      @default(0)
  currency   String   @default("THB")
  version    Int      @default(0)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("user_wallets")
}

model WalletTransaction {
  id              Int      @id @default(autoincrement())
  wallet_id       Int      @map("wallet_id")
  amount          Int
  balance_after   Int      @map("balance_after")
  type            String
  reference_type  String?  @map("reference_type")
  reference_id    Int?     @map("reference_id")
  idempotency_key String?  @unique @map("idempotency_key")
  created_at      DateTime @default(now()) @map("created_at")

  wallet               UserWallet           @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  payment_transactions PaymentTransaction[]

  @@index([wallet_id])
  @@index([type])
  @@map("wallet_transactions")
}

// ==============================================
// Payment (Normalized)
// ==============================================

model PaymentReceipt {
  id                  Int       @id @default(autoincrement())
  user_id             Int       @map("user_id")
  amount              Int       @default(0)
  slip_image_url      String?   @map("slip_image_url")
  status              String    @default("PENDING_VERIFICATION")
  rejection_reason    String?   @map("rejection_reason")
  paid_at             DateTime? @map("paid_at")
  month               Int?
  year                Int?
  transport_type      String?   @map("transport_type")
  // null = monthly intl slip; DOMESTIC_SHIPPING = domestic; WALLET_TOPUP = wallet top-up slip
  purpose             String?   @map("purpose")
  shipping_address_id Int?      @map("shipping_address_id")
  created_at          DateTime  @default(now()) @map("created_at")
  updated_at          DateTime  @updatedAt @map("updated_at")

  user               User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shipping_address   UserShippingAddress? @relation(fields: [shipping_address_id], references: [id], onDelete: SetNull)
  transactions       PaymentTransaction[]
  domestic_shipment  DomesticShipment?

  @@index([user_id])
  @@index([shipping_address_id])
  @@index([status])
  @@index([month, transport_type])
  @@index([user_id, purpose, status])
  @@map("payment_receipts")
}

model PaymentObligationType {
  id      Int    @id @default(autoincrement())
  code    String @unique
  name_th String @map("name_th")
  name_en String @map("name_en")

  obligations PaymentObligation[]

  @@map("payment_obligation_types")
}

model PaymentObligation {
  id                 Int       @id @default(autoincrement())
  auction_request_id Int?      @map("auction_request_id")
  user_id            Int?      @map("user_id")
  obligation_type_id Int       @map("obligation_type_id")
  amount             Int
  currency           String    @default("THB")
  due_date           DateTime? @map("due_date")
  status             String    @default("PENDING")
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")

  auction_request AuctionRequest?       @relation(fields: [auction_request_id], references: [id], onDelete: Cascade)
  user            User?                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  obligation_type PaymentObligationType @relation(fields: [obligation_type_id], references: [id], onDelete: Restrict)
  transactions    PaymentTransaction[]

  @@index([auction_request_id])
  @@index([user_id])
  @@index([status])
  @@map("payment_obligations")
}

model PaymentTransaction {
  id                    Int      @id @default(autoincrement())
  payment_obligation_id Int      @map("payment_obligation_id")
  payment_receipt_id    Int?     @map("payment_receipt_id")
  amount                Int
  paid_at               DateTime @map("paid_at")
  note                  String?
  slip_reference        String?  @map("slip_reference")
  source                String   @default("BANK_SLIP")
  wallet_transaction_id Int?     @map("wallet_transaction_id")
  status                String   @default("CONFIRMED")
  rejection_reason      String?  @map("rejection_reason")

  payment_obligation PaymentObligation  @relation(fields: [payment_obligation_id], references: [id], onDelete: Cascade)
  payment_receipt    PaymentReceipt?    @relation(fields: [payment_receipt_id], references: [id], onDelete: SetNull)
  wallet_transaction WalletTransaction? @relation(fields: [wallet_transaction_id], references: [id], onDelete: SetNull)

  @@index([payment_obligation_id])
  @@index([payment_receipt_id])
  @@index([status])
  @@map("payment_transactions")
}

// ==============================================
// Domestic shipment batch (รอบจัดส่งในไทยหลังจ่าย DOMESTIC_SHIPPING)
// ==============================================

model DomesticShipment {
  id                  Int       @id @default(autoincrement())
  user_id             Int       @map("user_id")
  payment_receipt_id  Int?      @unique @map("payment_receipt_id")
  shipping_address_id Int?      @map("shipping_address_id")
  // Denormalized copy of user_shipping_addresses at approve time (immutable for this round)
  snapshot_recipient_name String? @map("snapshot_recipient_name")
  snapshot_phone          String? @map("snapshot_phone")
  snapshot_address_line1    String? @map("snapshot_address_line1")
  snapshot_address_line2    String? @map("snapshot_address_line2")
  snapshot_subdistrict      String? @map("snapshot_subdistrict")
  snapshot_district         String? @map("snapshot_district")
  snapshot_province         String? @map("snapshot_province")
  snapshot_postal_code      String? @map("snapshot_postal_code")
  snapshot_country          String? @map("snapshot_country")
  tracking_number     String?   @map("tracking_number")
  carrier             String?
  shipped_at          DateTime? @map("shipped_at")
  created_at          DateTime  @default(now()) @map("created_at")
  updated_at          DateTime  @updatedAt @map("updated_at")

  user               User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payment_receipt    PaymentReceipt?      @relation(fields: [payment_receipt_id], references: [id], onDelete: SetNull)
  shipping_address   UserShippingAddress? @relation(fields: [shipping_address_id], references: [id], onDelete: SetNull)
  items              DomesticShipmentItem[]
  auction_requests   AuctionRequest[]

  @@index([user_id])
  @@index([shipping_address_id])
  @@map("domestic_shipments")
}

model DomesticShipmentItem {
  id                 Int @id @default(autoincrement())
  shipment_id        Int @map("shipment_id")
  auction_request_id Int @unique @map("auction_request_id")

  shipment        DomesticShipment @relation(fields: [shipment_id], references: [id], onDelete: Cascade)
  auction_request AuctionRequest   @relation(fields: [auction_request_id], references: [id], onDelete: Cascade)

  @@index([shipment_id])
  @@map("domestic_shipment_items")
}

// ==============================================
// Delivery Tracking (3 stages)
// ==============================================

model DeliveryStageType {
  id         Int    @id @default(autoincrement())
  code       String @unique
  name_th    String @map("name_th")
  name_en    String @map("name_en")
  sort_order Int    @default(0) @map("sort_order")

  stages DeliveryStage[]

  @@map("delivery_stage_types")
}

model DeliveryStage {
  id                 Int       @id @default(autoincrement())
  auction_request_id Int       @map("auction_request_id")
  stage_type_id      Int       @map("stage_type_id")
  status             String    @default("PENDING")
  tracking_number    String?   @map("tracking_number")
  carrier            String?
  shipped_at         DateTime? @map("shipped_at")
  delivered_at       DateTime? @map("delivered_at")
  is_paid            Boolean   @default(false) @map("is_paid")
  note               String?
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")

  auction_request AuctionRequest    @relation(fields: [auction_request_id], references: [id], onDelete: Cascade)
  stage_type      DeliveryStageType @relation(fields: [stage_type_id], references: [id], onDelete: Restrict)

  @@index([auction_request_id])
  @@index([status])
  @@map("delivery_stages")
}
