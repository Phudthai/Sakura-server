// ==============================================
// Sakura Database Schema
// ==============================================
// Matches deployed DB DDL — only tables used by API
//
// @docs https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================
// User Management
// ==============================================

model User {
  id             Int       @id @default(autoincrement())
  userCode       String    @unique @map("user_code")
  username       String?   @unique
  externalId     String?   @unique @map("external_id")
  email          String?   @unique
  password       String?
  name           String?
  phone          String?
  role           UserRole  @default(CUSTOMER)
  isEmailVerified Boolean  @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  auctionRequests    AuctionRequest[]
  wallet             UserWallet?
  paymentObligations PaymentObligation[]
  paymentReceipts    PaymentReceipt[]

  @@index([email])
  @@index([userCode])
  @@index([createdAt])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

// ==============================================
// Lot (จัดส่ง)
// ==============================================

model Lot {
  id               Int       @id @default(autoincrement())
  lotCode          String    @map("lot_code")
  intlShippingType String    @map("intl_shipping_type")
  startLotAt       DateTime? @map("start_lot_at")
  endLotAt         DateTime? @map("end_lot_at")
  arriveAt         DateTime? @map("arrive_at")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auctionRequests AuctionRequest[]

  @@unique([lotCode, intlShippingType])
  @@index([lotCode])
  @@index([intlShippingType])
  @@index([intlShippingType, endLotAt])
  @@map("lots")
}

// ==============================================
// Auction Tracking
// ==============================================

model AuctionRequest {
  id           Int       @id @default(autoincrement())
  userId       Int?
  url          String
  web          String?   @default("yahoo")
  itemId       String?   @map("item_id")
  title        String?
  imageUrl     String?
  endTime      DateTime?
  status           String    @default("pending")
  currentPrice     Int?
  currentPriceBaht Int?      @map("current_price_baht")
  note             String?
  bidResult         String?   @map("bid_result")
  weightGram        Int?      @map("weight_gram")
  intlShippingType  String?   @map("intl_shipping_type")
  lotId              Int?      @map("lot_id")
  boughtAt          DateTime? @map("bought_at")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  lot        Lot?              @relation(fields: [lotId], references: [id], onDelete: SetNull)
  priceLogs  AuctionPriceLog[]
  paymentObligations PaymentObligation[]
  deliveryStages DeliveryStage[]

  @@index([status])
  @@index([userId])
  @@index([web])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("auction_requests")
}

model AuctionPriceLog {
  id               Int      @id @default(autoincrement())
  auctionRequestId Int
  price            Int
  bidCount         Int      @default(0)
  status           String   @default("pending")
  biddedBy         Int?
  recordedAt       DateTime @default(now())

  auctionRequest AuctionRequest @relation(fields: [auctionRequestId], references: [id], onDelete: Cascade)
  staff          Staff?         @relation(fields: [biddedBy], references: [id], onDelete: SetNull)

  @@index([auctionRequestId])
  @@index([biddedBy])
  @@index([status])
  @@index([status, recordedAt])
  @@map("auction_price_logs")
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceLogs AuctionPriceLog[]

  @@map("staffs")
}

// ==============================================
// User Wallet
// ==============================================

model UserWallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  balance   Int      @default(0)
  currency  String   @default("THB")
  version   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("user_wallets")
}

model WalletTransaction {
  id              Int      @id @default(autoincrement())
  walletId        Int      @map("wallet_id")
  amount          Int
  balanceAfter    Int      @map("balance_after")
  type            String
  referenceType   String?  @map("reference_type")
  referenceId     Int?     @map("reference_id")
  idempotencyKey  String?  @unique @map("idempotency_key")
  createdAt       DateTime @default(now()) @map("created_at")

  wallet              UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  paymentTransactions PaymentTransaction[]

  @@index([walletId])
  @@index([type])
  @@map("wallet_transactions")
}

// ==============================================
// Payment (Normalized)
// ==============================================

model PaymentReceipt {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  amount          Int       @default(0)
  slipImageUrl    String?   @map("slip_image_url")
  status          String    @default("PENDING_VERIFICATION")
  rejectionReason String?   @map("rejection_reason")
  paidAt          DateTime? @map("paid_at")
  month           Int?
  year            Int?
  transportType   String?   @map("transport_type")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([status])
  @@index([month, transportType])
  @@map("payment_receipts")
}

model PaymentObligationType {
  id     Int      @id @default(autoincrement())
  code   String   @unique
  nameTh String   @map("name_th")
  nameEn String   @map("name_en")

  obligations PaymentObligation[]

  @@map("payment_obligation_types")
}

model PaymentObligation {
  id                 Int       @id @default(autoincrement())
  auctionRequestId   Int?      @map("auction_request_id")
  userId             Int?      @map("user_id")
  obligationTypeId   Int       @map("obligation_type_id")
  amount             Int
  currency           String    @default("THB")
  dueDate            DateTime? @map("due_date")
  status             String    @default("PENDING")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  auctionRequest AuctionRequest?    @relation(fields: [auctionRequestId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  obligationType PaymentObligationType @relation(fields: [obligationTypeId], references: [id], onDelete: Restrict)
  transactions   PaymentTransaction[]

  @@index([auctionRequestId])
  @@index([userId])
  @@index([status])
  @@map("payment_obligations")
}

model PaymentTransaction {
  id                    Int      @id @default(autoincrement())
  paymentObligationId   Int      @map("payment_obligation_id")
  paymentReceiptId      Int?     @map("payment_receipt_id")
  amount                Int
  paidAt                DateTime @map("paid_at")
  note                  String?
  slipReference         String?  @map("slip_reference")
  source                String   @default("BANK_SLIP")
  walletTransactionId   Int?     @map("wallet_transaction_id")
  status                String   @default("CONFIRMED")
  rejectionReason       String?  @map("rejection_reason")

  paymentObligation PaymentObligation @relation(fields: [paymentObligationId], references: [id], onDelete: Cascade)
  paymentReceipt    PaymentReceipt?   @relation(fields: [paymentReceiptId], references: [id], onDelete: SetNull)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([paymentObligationId])
  @@index([paymentReceiptId])
  @@index([status])
  @@map("payment_transactions")
}

// ==============================================
// Delivery Tracking (3 stages)
// ==============================================

model DeliveryStageType {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  nameTh    String   @map("name_th")
  nameEn    String   @map("name_en")
  sortOrder Int      @default(0) @map("sort_order")

  stages DeliveryStage[]

  @@map("delivery_stage_types")
}

model DeliveryStage {
  id                 Int       @id @default(autoincrement())
  auctionRequestId   Int       @map("auction_request_id")
  stageTypeId        Int       @map("stage_type_id")
  status             String    @default("PENDING")
  trackingNumber     String?   @map("tracking_number")
  carrier            String?
  shippedAt          DateTime? @map("shipped_at")
  deliveredAt        DateTime? @map("delivered_at")
  note               String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  auctionRequest AuctionRequest   @relation(fields: [auctionRequestId], references: [id], onDelete: Cascade)
  stageType      DeliveryStageType @relation(fields: [stageTypeId], references: [id], onDelete: Restrict)

  @@index([auctionRequestId])
  @@index([status])
  @@map("delivery_stages")
}
