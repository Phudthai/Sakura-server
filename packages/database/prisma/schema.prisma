// ==============================================
// Sakura Database Schema
// ==============================================
// Matches deployed DB DDL — only tables used by API
//
// @docs https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================
// User Management
// ==============================================

model User {
  id             Int       @id @default(autoincrement())
  userCode       String?   @unique @map("user_code")
  externalId     String?   @unique @map("external_id")
  email          String    @unique
  password       String
  name           String
  phone          String?
  role           UserRole  @default(CUSTOMER)
  isEmailVerified Boolean  @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  auctionRequests AuctionRequest[]

  @@index([email])
  @@index([createdAt])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

// ==============================================
// Auction Tracking
// ==============================================

model AuctionRequest {
  id           Int       @id @default(autoincrement())
  userId       Int?
  url          String
  yahooItemId  String?
  title        String?
  imageUrl     String?
  endTime      DateTime?
  status       String    @default("pending")
  currentPrice Int?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  priceLogs  AuctionPriceLog[]

  @@index([status])
  @@index([userId])
  @@map("auction_requests")
}

model AuctionPriceLog {
  id               Int      @id @default(autoincrement())
  auctionRequestId Int
  price            Int
  bidCount         Int      @default(0)
  status           String   @default("pending")
  biddedBy         Int?
  recordedAt       DateTime @default(now())

  auctionRequest AuctionRequest @relation(fields: [auctionRequestId], references: [id], onDelete: Cascade)
  staff          Staff?         @relation(fields: [biddedBy], references: [id], onDelete: SetNull)

  @@index([auctionRequestId])
  @@index([biddedBy])
  @@map("auction_price_logs")
}

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceLogs AuctionPriceLog[]

  @@map("staffs")
}
