# ===========================================
# Sakura API — Environment Variables
# ===========================================
# Copy to .env and fill in values
# cp .env.example .env
#
# หมายเหตุ: .env ต้องอยู่ที่ root ของโปรเจกต์
# รัน migration ด้วย: npm run db:migrate (จาก root)

NODE_ENV=production

# Database (required)
# Optional: ?connection_limit=10&connect_timeout=10 for managed PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth (required — generate new secret for production!)
JWT_SECRET=your-secret-at-least-32-chars

# Server
API_PORT=4000
API_BASE_PATH=/api

# Frontend (for register_url in backoffice)
FRONTEND_URL=http://localhost:3000

# Auction cron
AUCTION_POLL_INTERVAL_SECONDS=180
AUCTION_CRON_TEST_MODE=false

# Proxy สำหรับ Yahoo scraping (optional — หลีกเลี่ยง block / สินค้า 18+)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
